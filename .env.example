# ==========================================
# Dignify - Entorno de Producción / Local
# ==========================================

# 1. Base de Datos (PostgreSQL via Railway o Supabase con pgvector habilitado)
DATABASE_URL="postgresql://user:password@localhost:5432/dignify?schema=public"

# 2. NextAuth (Autenticación Global)
# Generar usando: openssl rand -base64 32
NEXTAUTH_SECRET="tu-secreto-super-seguro"
NEXTAUTH_URL="http://localhost:3000" # En prod: https://dignify.fm

# Oauth Providers
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-google-client-secret"
SPOTIFY_CLIENT_ID="tu-spotify-client-id"
SPOTIFY_CLIENT_SECRET="tu-spotify-client-secret"

# 3. Aggregation Engines (Data Sources)
YOUTUBE_API_KEY="AIzaSyTuClaveDeYouTubeAqui"
SOUNDCLOUD_CLIENT_ID="opcional-tu-clientId-en-sc"

# 4. Discovery Engine (Semantic AI)
OPENAI_API_KEY="sk-tu-api-key-de-openai"

# 5. Puertos & Red
# Para la app Web de NextJS
NEXT_PUBLIC_API_URL="http://localhost:3001" # En prod: https://api.dignify.fm
# Para la API de NestJS
FRONTEND_URL="http://localhost:3000" # En prod: https://dignify.fm
PORT=3001
