{
  "name": "dignify-project",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev": "npm run dev:web & npm run dev:api",
    "build:web": "npm run build --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "build": "npm run build:web && npm run build:api",
    "db:push": "npx prisma db push --schema=packages/database/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate deploy --schema=packages/database/prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=packages/database/prisma/schema.prisma"
  }
}
